# This will tell vite what port to listen on. Our tests refer to this to know
# how to connect to vite
NEEMS_REACT_PORT=5173

# Vite will use this to know where to send /api calls.  Localhost:8000 is the
# default listen address of neems-core.  If you are doing dev on the front end
# and don't want to run your own backend, you can set it to
# staging.neems.newtown.energy.
NEEMS_CORE_SERVER=http://127.0.0.1:8000

# Set this so generated types end up in the right place.  If unset, we'll assume
# your setup looks like James's two dir structure: neems with two subdirs, core
# and react.
#NEEMS_TS_OUTPUT_DIR=

# GitHub Packages auth token for installing @newtown-energy/types.
# Only needed for local development outside Docker.
# Easiest method using gh CLI:
#   gh auth refresh -s read:packages  # One-time: add required scope
#   export GITHUB_PACKAGES_TOKEN=$(gh auth token)
# Or create a PAT at https://github.com/settings/tokens with read:packages scope.
#GITHUB_PACKAGES_TOKEN=
